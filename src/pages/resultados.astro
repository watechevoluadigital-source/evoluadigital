---
import Layout from '../layouts/Layout.astro';
import { withBase } from '../utils/paths';

const cases = [
  {
    segmento: 'E-commerce',
    titulo: 'Escala de vendas com mídia paga',
    resumo:
      'Reestruturação de campanhas, catálogo e mensagens — foco em ROAS sustentável e sazonalidade.',
    destaque: 'Mídia + criativos + página de oferta',
  },
  {
    segmento: 'Serviços locais',
    titulo: 'Demanda qualificada na região',
    resumo:
      'Geolocalização, prova social e formulários otimizados para reduzir lead ruim e agendar mais.',
    destaque: 'Google + Meta + landing',
  },
  {
    segmento: 'B2B',
    titulo: 'Funil de conteúdo e captação',
    resumo:
      'Conteúdo educativo, nutrição e anúncios para mover decisores entre etapas com clareza.',
    destaque: 'LinkedIn / Meta conforme ICP',
  },
] as const;
---

<Layout
  title="Resultados"
  description="Exemplos de frentes estratégicas e estruturas de resultado — Evolua Digital. A versão final pode receber cases e números reais conforme autorização."
>
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <header class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">
        Frentes estratégicas
      </p>
      <h1 class="mt-2 text-4xl font-bold tracking-tight text-white">
        Resultados
      </h1>
      <p class="mt-4 text-lg text-silver-400">
        Abaixo, mostramos <strong class="font-medium text-silver-200">exemplos de frentes estratégicas</strong>
        que ajudam a visualizar como a Evolua Digital organiza projetos,
        prioridades e metas. Cases reais, números e marcas podem ser adicionados
        na versão final com a devida autorização.
      </p>
    </header>

    <ul class="mt-16 space-y-8">
      {
        cases.map((c, i) => (
          <li>
            <article
              class="rounded-2xl border border-white/10 bg-navy-900/35 p-8 backdrop-blur-sm lg:flex lg:gap-10 lg:p-10"
              aria-labelledby={`case-${i}-title`}
            >
              <div class="shrink-0">
                <p class="text-xs font-semibold uppercase tracking-wider text-accent">
                  {c.segmento}
                </p>
                <h2
                  id={`case-${i}-title`}
                  class="mt-2 text-xl font-semibold text-white lg:text-2xl"
                >
                  {c.titulo}
                </h2>
              </div>
              <div class="mt-6 flex-1 lg:mt-0">
                <p class="text-sm leading-relaxed text-silver-400">{c.resumo}</p>
                <p class="mt-4 text-sm font-medium text-silver-300">
                  <span class="text-silver-500">Foco:</span> {c.destaque}
                </p>
              </div>
            </article>
          </li>
        ))
      }
    </ul>

    <p class="mt-12 text-center text-sm text-silver-500">
      Quer entender como isso se traduz no seu contexto? Na conversa inicial,
      mostramos referências compatíveis com o seu momento, segmento e objetivo.
    </p>

    <div class="mt-10 flex justify-center">
      <a
        href={withBase('/contato')}
        class="inline-flex rounded-lg bg-accent px-6 py-3 text-sm font-semibold text-navy-950 shadow-glow transition hover:bg-accent-bright"
      >
        Solicitar apresentação
      </a>
    </div>
  </div>
</Layout>
