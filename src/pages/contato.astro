---
import Layout from '../layouts/Layout.astro';
import { whatsappUrl } from '../data/contato';

const emailContato = 'contato@evoluadigital.com.br';
const telefoneDisplay = '(00) 00000-0000';
const whatsappHref = whatsappUrl;
---

<Layout
  title="Contato"
  description="Solicite o diagnóstico gratuito ou fale com a Evolua Digital. Formulário curto — nome, e-mail, WhatsApp e contexto."
>
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <header class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">
        Contato
      </p>
      <h1 class="mt-2 text-4xl font-bold tracking-tight text-white">
        Diagnóstico gratuito do seu marketing
      </h1>
      <p class="mt-4 text-lg text-silver-400">
        Preencha em menos de um minuto. <strong class="font-medium text-silver-200"
          >Meta:</strong
        > retorno em até <strong class="font-medium text-silver-200"
          >1 dia útil</strong
        > com próximos passos (e honestidade se não for o momento de contratar).
      </p>
      <p class="mt-3 text-sm text-silver-500">
        O envio abre seu app de e-mail com a mensagem montada — não precisa de
        servidor. Se preferir, use WhatsApp ao lado.
      </p>
    </header>

    <div class="mt-14 grid gap-12 lg:grid-cols-2">
      <div class="space-y-8">
        <section aria-labelledby="canais-heading">
          <h2 id="canais-heading" class="text-lg font-semibold text-white">
            Canais diretos
          </h2>
          <ul class="mt-4 space-y-4 text-sm">
            <li>
              <span class="block text-silver-500">E-mail</span>
              <a
                class="font-medium text-accent hover:text-accent-bright"
                href={`mailto:${emailContato}`}
              >
                {emailContato}
              </a>
            </li>
            <li>
              <span class="block text-silver-500">WhatsApp</span>
              <a
                class="font-medium text-accent hover:text-accent-bright"
                href={whatsappHref}
                target="_blank"
                rel="noopener noreferrer"
              >
                {telefoneDisplay}
              </a>
            </li>
          </ul>
        </section>
        <p class="text-xs text-silver-600">
          Campos mínimos = mais conversão. Empresa e observações são opcionais.
        </p>
      </div>

      <section
        class="rounded-2xl border border-white/10 bg-navy-900/40 p-6 backdrop-blur-sm sm:p-8"
        aria-labelledby="form-heading"
      >
        <h2 id="form-heading" class="text-lg font-semibold text-white">
          Formulário rápido
        </h2>
        <p id="form-desc" class="mt-1 text-sm text-silver-500">
          Nome e e-mail são obrigatórios. Demais campos ajudam a responder com
          mais precisão.
        </p>
        <form
          class="mt-6 space-y-4"
          id="form-contato"
          aria-describedby="form-desc"
        >
          <div>
            <label for="nome" class="block text-sm font-medium text-silver-300"
              >Nome <span class="text-red-400">*</span></label
            >
            <input
              id="nome"
              name="nome"
              type="text"
              autocomplete="name"
              required
              class="mt-1.5 w-full rounded-lg border border-white/10 bg-navy-950/80 px-3 py-2.5 text-sm text-white placeholder:text-silver-600 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
              placeholder="Seu nome"
            />
          </div>
          <div>
            <label
              for="email"
              class="block text-sm font-medium text-silver-300"
              >E-mail <span class="text-red-400">*</span></label
            >
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              required
              class="mt-1.5 w-full rounded-lg border border-white/10 bg-navy-950/80 px-3 py-2.5 text-sm text-white placeholder:text-silver-600 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
              placeholder="voce@empresa.com"
            />
          </div>
          <div>
            <label
              for="whatsapp"
              class="block text-sm font-medium text-silver-300"
              >WhatsApp</label
            >
            <input
              id="whatsapp"
              name="whatsapp"
              type="tel"
              autocomplete="tel"
              class="mt-1.5 w-full rounded-lg border border-white/10 bg-navy-950/80 px-3 py-2.5 text-sm text-white placeholder:text-silver-600 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
              placeholder="(00) 00000-0000"
            />
          </div>
          <div>
            <label
              for="empresa"
              class="block text-sm font-medium text-silver-300"
              >Empresa <span class="text-silver-500">(opcional)</span></label
            >
            <input
              id="empresa"
              name="empresa"
              type="text"
              autocomplete="organization"
              class="mt-1.5 w-full rounded-lg border border-white/10 bg-navy-950/80 px-3 py-2.5 text-sm text-white placeholder:text-silver-600 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
              placeholder="Nome da empresa ou projeto"
            />
          </div>
          <div>
            <label
              for="mensagem"
              class="block text-sm font-medium text-silver-300"
              >Contexto <span class="text-silver-500">(opcional)</span></label
            >
            <textarea
              id="mensagem"
              name="mensagem"
              rows="3"
              class="mt-1.5 w-full resize-y rounded-lg border border-white/10 bg-navy-950/80 px-3 py-2.5 text-sm text-white placeholder:text-silver-600 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
              placeholder="Segmento, site, investimento em mídia hoje…"
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full rounded-lg bg-accent py-3 text-sm font-semibold text-navy-950 shadow-glow transition hover:bg-accent-bright sm:w-auto sm:px-8"
          >
            Quero meu diagnóstico — enviar por e-mail
          </button>
          <p id="form-status" class="hidden text-sm text-accent-bright" role="status"></p>
        </form>
      </section>
    </div>
  </div>
</Layout>

<script define:vars={{ emailContato }}>
  const form = document.getElementById('form-contato');
  const statusEl = document.getElementById('form-status');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form) return;
    const data = new FormData(form);
    const nome = String(data.get('nome') ?? '').trim();
    const email = String(data.get('email') ?? '').trim();
    const whatsapp = String(data.get('whatsapp') ?? '').trim();
    const empresa = String(data.get('empresa') ?? '').trim();
    let mensagem = String(data.get('mensagem') ?? '').trim();
    if (!mensagem) mensagem = '(Pedido de diagnóstico via site — sem texto adicional.)';

    const subject = encodeURIComponent(`Diagnóstico gratuito — ${nome}`);
    const body = encodeURIComponent(
      `Nome: ${nome}\nE-mail: ${email}\nWhatsApp: ${whatsapp || '—'}\nEmpresa: ${empresa || '—'}\n\n${mensagem}`
    );
    window.location.href = `mailto:${emailContato}?subject=${subject}&body=${body}`;

    if (statusEl) {
      statusEl.textContent =
        'Se o e-mail não abrir, use o WhatsApp ou copie o endereço ao lado.';
      statusEl.classList.remove('hidden');
    }
  });
</script>
