---
import { whatsappUrl } from '../data/contato';
import { withBase } from '../utils/paths';
---

<div
  class="fixed bottom-0 left-0 right-0 z-[60] border-t border-white/10 bg-navy-950/95 px-3 pt-2 backdrop-blur-md md:hidden"
  style="padding-bottom: max(0.5rem, env(safe-area-inset-bottom));"
  role="region"
  aria-label="Ações rápidas"
>
  <div class="mx-auto flex max-w-lg gap-2 pb-2">
    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="flex flex-1 items-center justify-center gap-2 rounded-lg border border-[#25D366]/40 bg-[#25D366]/15 py-3 text-sm font-semibold text-[#25D366] transition hover:bg-[#25D366]/25"
    >
      <span aria-hidden="true">+</span>
      WhatsApp
    </a>
    <a
      href={withBase('/contato')}
      class="flex flex-1 items-center justify-center rounded-lg bg-accent py-3 text-sm font-semibold text-navy-950 shadow-glow transition hover:bg-accent-bright"
    >
      Diagnóstico grátis
    </a>
  </div>
</div>
