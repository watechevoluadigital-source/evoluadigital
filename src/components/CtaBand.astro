---
interface LinkBtn {
  href: string;
  label: string;
  external?: boolean;
}

interface Props {
  titulo: string;
  texto?: string;
  primario: LinkBtn;
  secundario?: LinkBtn;
}

const { titulo, texto, primario, secundario } = Astro.props;
---

<div
  class="rounded-2xl border border-accent/30 bg-gradient-to-r from-accent/10 via-navy-900/60 to-navy-900/40 p-6 sm:p-8"
>
  <div
    class="flex flex-col items-start justify-between gap-6 lg:flex-row lg:items-center"
  >
    <div>
      <p class="text-lg font-semibold text-white sm:text-xl">{titulo}</p>
      {texto && <p class="mt-2 max-w-xl text-sm text-silver-400">{texto}</p>}
    </div>
    <div class="flex w-full flex-col gap-3 sm:w-auto sm:flex-row sm:flex-wrap">
      <a
        href={primario.href}
        target={primario.external ? '_blank' : undefined}
        rel={primario.external ? 'noopener noreferrer' : undefined}
        class="inline-flex justify-center rounded-lg bg-accent px-6 py-3 text-sm font-semibold text-navy-950 shadow-glow transition hover:bg-accent-bright"
      >
        {primario.label}
      </a>
      {
        secundario && (
          <a
            href={secundario.href}
            target={secundario.external ? '_blank' : undefined}
            rel={secundario.external ? 'noopener noreferrer' : undefined}
            class="inline-flex justify-center rounded-lg border border-white/20 px-6 py-3 text-sm font-semibold text-white transition hover:border-accent/40 hover:bg-white/5"
          >
            {secundario.label}
          </a>
        )
      }
    </div>
  </div>
</div>
