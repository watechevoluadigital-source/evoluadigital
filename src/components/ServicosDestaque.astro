---
import { withBase } from '../utils/paths';

const itens = [
  {
    titulo: 'Tráfego pago',
    texto: 'Meta Ads, Google e campanhas com mensuração sólida e otimização por conversão.',
    href: '/servicos',
  },
  {
    titulo: 'Conteúdo & social',
    texto: 'Presença consistente, calendário e criativos que sustentam a conversa com o público.',
    href: '/servicos',
  },
  {
    titulo: 'Performance & páginas',
    texto: 'Landings rápidas, copy orientada a CRO e integração com pixels e eventos.',
    href: '/servicos',
  },
  {
    titulo: 'Consultoria',
    texto: 'Quando você já tem time ou fornecedores — priorizamos o que mexe no resultado.',
    href: '/servicos',
  },
] as const;
---

<section
  class="mx-auto max-w-6xl px-4 py-20 sm:px-6 lg:px-8"
  aria-labelledby="servicos-destaque-heading"
>
  <div class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-end">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">
        Serviços
      </p>
      <h2
        id="servicos-destaque-heading"
        class="mt-2 text-2xl font-bold tracking-tight text-white sm:text-3xl"
      >
        O que podemos fazer pelo seu crescimento
      </h2>
    </div>
    <a
      href={withBase('/servicos')}
      class="text-sm font-semibold text-accent transition hover:text-accent-bright"
    >
      Ver todos os serviços →
    </a>
  </div>
  <ul class="mt-12 grid gap-6 sm:grid-cols-2">
    {
      itens.map((item) => (
        <li>
          <a
            href={withBase(item.href)}
            class="group flex h-full flex-col rounded-2xl border border-white/10 bg-navy-900/35 p-6 transition hover:border-accent/35 hover:bg-navy-900/55"
          >
            <h3 class="text-lg font-semibold text-white group-hover:text-accent">
              {item.titulo}
            </h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-silver-400">
              {item.texto}
            </p>
            <span class="mt-4 text-sm font-medium text-accent opacity-90">
              Saiba mais
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</section>
