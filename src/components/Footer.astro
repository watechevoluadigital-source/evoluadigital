---
import SocialLink from './SocialLink.astro';
import { whatsappUrl } from '../data/contato';
import { withBase } from '../utils/paths';

const year = new Date().getFullYear();

/** Troque pelos links reais das redes do cliente. */
const redesSociais = [
  {
    network: 'x' as const,
    href: 'https://x.com/',
    label: 'Evolua Digital no X (Twitter)',
  },
  {
    network: 'facebook' as const,
    href: 'https://www.facebook.com/',
    label: 'Evolua Digital no Facebook',
  },
  {
    network: 'instagram' as const,
    href: 'https://www.instagram.com/',
    label: 'Evolua Digital no Instagram',
  },
  {
    network: 'tiktok' as const,
    href: 'https://www.tiktok.com/',
    label: 'Evolua Digital no TikTok',
  },
  {
    network: 'youtube' as const,
    href: 'https://www.youtube.com/',
    label: 'Evolua Digital no YouTube',
  },
  {
    network: 'whatsapp' as const,
    href: whatsappUrl,
    label: 'Falar com a Evolua Digital no WhatsApp',
  },
];
---

<footer class="border-t border-white/5 bg-navy-900/50">
  <div
    class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:flex lg:items-start lg:justify-between lg:px-8"
  >
    <div class="max-w-md">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">
        Evolua Digital
      </p>
      <p class="mt-2 text-sm text-silver-400">
        Marketing digital com foco em performance, marca e crescimento
        sustentável para o seu negócio.
      </p>
      <a
        href={withBase('/contato')}
        class="mt-4 inline-flex rounded-lg bg-accent px-4 py-2 text-xs font-semibold text-navy-950 shadow-glow transition hover:bg-accent-bright"
      >
        Diagnóstico gratuito
      </a>
    </div>
    <div
      class="mt-8 flex flex-col gap-8 lg:mt-0 lg:items-end"
    >
      <nav class="flex flex-wrap gap-x-6 gap-y-2" aria-label="Rodapé">
        <a href={withBase('/servicos')} class="text-sm text-silver-300 hover:text-white"
          >Serviços</a
        >
        <a href={withBase('/insights')} class="text-sm text-silver-300 hover:text-white"
          >Insights</a
        >
        <a href={withBase('/sobre')} class="text-sm text-silver-300 hover:text-white"
          >Sobre</a
        >
        <a href={withBase('/resultados')} class="text-sm text-silver-300 hover:text-white"
          >Resultados</a
        >
        <a href={withBase('/contato')} class="text-sm text-silver-300 hover:text-white"
          >Contato</a
        >
      </nav>
      <div class="w-full lg:w-auto">
        <p
          class="mb-3 text-center text-xs font-medium uppercase tracking-wider text-silver-500 lg:text-right"
          id="footer-social-heading"
        >
          Redes sociais
        </p>
        <ul
          class="flex flex-wrap justify-center gap-3 lg:justify-end"
          aria-labelledby="footer-social-heading"
        >
          {
            redesSociais.map((r) => (
              <li>
                <SocialLink
                  href={r.href}
                  label={r.label}
                  network={r.network}
                />
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
  <div class="border-t border-white/5 py-6">
    <p class="text-center text-xs text-silver-500">
      © {year} Evolua Digital. Todos os direitos reservados.
    </p>
  </div>
</footer>
