---
import {
  emailContato,
  enderecoContato,
  horarioAtendimento,
  telefoneDisplay,
  whatsappUrl,
} from '../data/contato';
import { withBase } from '../utils/paths';

const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 bg-navy-900/50">
  <div
    class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:flex lg:items-start lg:justify-between lg:px-8"
  >
    <div class="max-w-md">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">
        Evolua Digital
      </p>
      <p class="mt-2 text-sm text-silver-400">
        Marketing digital com foco em performance, marca e crescimento
        sustentável para o seu negócio.
      </p>
      <div class="mt-4 space-y-2 text-sm text-silver-400">
        <p>{telefoneDisplay}</p>
        <p>{emailContato}</p>
        <p>{enderecoContato}</p>
      </div>
    </div>
    <div
      class="mt-8 flex flex-col gap-8 lg:mt-0 lg:items-end"
    >
      <nav class="flex flex-wrap gap-x-6 gap-y-2" aria-label="Rodapé">
        <a href={withBase('/servicos')} class="text-sm text-silver-300 hover:text-white"
          >Serviços</a
        >
        <a href={withBase('/insights')} class="text-sm text-silver-300 hover:text-white"
          >Insights</a
        >
        <a href={withBase('/sobre')} class="text-sm text-silver-300 hover:text-white"
          >Sobre</a
        >
        <a href={withBase('/resultados')} class="text-sm text-silver-300 hover:text-white"
          >Resultados</a
        >
        <a href={withBase('/contato')} class="text-sm text-silver-300 hover:text-white"
          >Contato</a
        >
      </nav>
      <div class="w-full max-w-sm lg:max-w-xs lg:text-right">
        <p class="text-xs font-semibold uppercase tracking-wider text-silver-500">
          Atendimento
        </p>
        <p class="mt-2 text-sm leading-relaxed text-silver-500">
          {horarioAtendimento}
        </p>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex rounded-lg border border-[#25D366]/35 bg-[#25D366]/10 px-4 py-2 text-xs font-semibold text-[#25D366] transition hover:bg-[#25D366]/20"
        >
          Chamar no WhatsApp
        </a>
      </div>
    </div>
  </div>
  <div class="border-t border-white/5 py-6">
    <p class="text-center text-xs text-silver-500">
      © {year} Evolua Digital. Todos os direitos reservados.
    </p>
  </div>
</footer>
