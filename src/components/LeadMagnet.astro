---
import { withBase } from '../utils/paths';

const itens = [
  'Leitura rápida do seu funil e canais atuais',
  '3 prioridades objetivas para as próximas semanas',
  'Sugestão honesta se faz sentido trabalharmos juntos — ou não',
] as const;
---

<section
  class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8"
  aria-labelledby="lead-magnet-heading"
>
  <div
    class="overflow-hidden rounded-2xl border border-accent/25 bg-gradient-to-br from-navy-800/90 via-navy-900/80 to-navy-950 p-8 sm:p-10 lg:flex lg:items-center lg:justify-between lg:gap-12 lg:p-12"
  >
    <div class="max-w-xl">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent-bright">
        Oferta de entrada
      </p>
      <h2
        id="lead-magnet-heading"
        class="mt-2 text-2xl font-bold text-white sm:text-3xl"
      >
        Diagnóstico gratuito do seu marketing digital
      </h2>
      <p class="mt-3 text-silver-400">
        Sem compromisso. Você ganha clareza, e nós avaliamos se há encaixe para uma proposta.
      </p>
      <ul class="mt-6 space-y-2">
        {
          itens.map((t) => (
            <li class="flex gap-2 text-sm text-silver-300">
              <span class="text-accent" aria-hidden="true">
                ✓
              </span>
              {t}
            </li>
          ))
        }
      </ul>
    </div>
    <div class="mt-8 flex shrink-0 flex-col gap-3 lg:mt-0">
      <a
        href={withBase('/contato')}
        class="inline-flex justify-center rounded-lg bg-accent px-8 py-3.5 text-center text-base font-semibold text-navy-950 shadow-glow transition hover:bg-accent-bright"
      >
        Quero meu diagnóstico gratuito
      </a>
      <a
        href={withBase('/contato#form-contato')}
        class="text-center text-sm font-medium text-silver-400 underline-offset-2 hover:text-white hover:underline"
      >
        Ou preencha o formulário rápido
      </a>
    </div>
  </div>
</section>
