---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class:list={['flex min-w-0 shrink-0 items-center', className]}>
  <img
    src="/logo.jpeg"
    alt="Evolua Digital"
    class="h-16 w-auto max-w-[min(92vw,520px)] object-contain object-left sm:h-20 md:h-24 lg:h-[6.75rem]"
    width="520"
    height="120"
    loading="eager"
    decoding="async"
  />
</div>
